# =============================================================================
# ABW-BOS — .dockerignore
# Keeps build context small for fast, cacheable Docker builds.
# =============================================================================

# Version control
.git
.gitignore
.gitattributes

# Dependencies (will be installed inside the image)
node_modules

# Build outputs
.next
out
dist
build

# Local databases & uploads (NEVER bake into image)
db
*.db
*.db-journal
*.sqlite
*.sqlite3
upload
uploads

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Env files (use real secrets via docker-compose env / runtime env)
.env
.env.*
!.env.production.example

# Editor / OS
.DS_Store
.idea
.vscode
*.swp
*.swo
*~

# Test coverage
coverage
.nyc_output

# Cache
.cache
.eslintcache
.tsbuildinfo

# Skills tooling (not needed at runtime — these are dev-time assistants)
skills

# Misc project files not needed at runtime
worklog.md
Caddyfile
README.md
